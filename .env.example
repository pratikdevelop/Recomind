# ── Copy to .env — NEVER commit this file ─────────────────────────────────────

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/knowledge_base?retryWrites=true&w=majority
DB_NAME=knowledge_base
COLLECTION=docs
INDEX_NAME=vector_idx

# ── Embedding Backend ─────────────────────────────────────────────────────────
# 'docker' → uses ai/nomic-embed-text-v1.5 via Docker Model Runner (recommended)
# 'local'  → uses sentence-transformers (no Docker needed)
EMBED_BACKEND=docker

# Docker Model Runner embedding (your model: ai/nomic-embed-text-v1.5:latest)
DOCKER_URL=http://localhost:12434
DOCKER_EMBED_MODEL=nomic-embed-text-v1.5

# Local fallback embedding model (only used when EMBED_BACKEND=local)
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Chunking
CHUNK_SIZE=450
CHUNK_OVERLAP=80
SCORE_THRESHOLD=0.68
SEARCH_LIMIT=5

# ── Razorpay (India — UPI, Cards, Net Banking) ───────────────────────────────
# Sign up free: https://razorpay.com → Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_PLAN_PRO=plan_XXXXXXXXXXXXXXXX     # from: py setup_razorpay.py
RAZORPAY_PLAN_TEAM=plan_XXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=                    # Dashboard → Webhooks → Secret

# ── PayPal Payments ──────────────────────────────────────────────────────────
# 1. Create app: https://developer.paypal.com/dashboard/applications
# 2. Create subscription plans in PayPal Dashboard → Catalog → Subscription Plans
# 3. Copy Plan IDs below (format: P-XXXXXXXXXXXXXXXX)
PAYPAL_MODE=sandbox                     # sandbox (testing) | live (production)
PAYPAL_CLIENT_ID=                       # from PayPal app credentials
PAYPAL_SECRET=                          # from PayPal app credentials
PAYPAL_PLAN_PRO=                        # P-XXXXXXXX (Pro monthly plan ID)
PAYPAL_PLAN_TEAM=                       # P-XXXXXXXX (Team monthly plan ID)
PAYPAL_WEBHOOK_ID=                      # from PayPal Dashboard → Webhooks
APP_URL=http://localhost:8000           # change to your domain in production

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail setup: Google Account → Security → App Passwords → Generate
# Use the 16-char app password (not your Gmail login password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx    # 16-char Gmail App Password
EMAIL_FROM=your@gmail.com
EMAIL_FROM_NAME=RecoMind

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE-THIS-TO-A-RANDOM-64-CHAR-STRING
JWT_LIFETIME_SECONDS=604800     # 7 days

# ── LLM Backend ───────────────────────────────────────────────────────────────
# 'docker'      → uses ai/llama3.2 via Docker Model Runner  ← YOUR SETUP
# 'ollama'      → standalone Ollama install
# 'groq'        → free cloud API (console.groq.com)
# 'huggingface' → free HuggingFace Inference API
LLM_BACKEND=docker

# Docker Model Runner LLM (your model: ai/llama3.2:latest)
DOCKER_MODEL=llama3.2

# Ollama (only if LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Groq (only if LLM_BACKEND=groq — free key at console.groq.com, no CC)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# HuggingFace (only if LLM_BACKEND=huggingface — free at huggingface.co/settings/tokens)
HF_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

MAX_TOKENS=512

# Auto-ingest folder on startup
DOCS_FOLDER=documents

# ── Re-ranker ─────────────────────────────────────────────────────────────────
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=3          # final chunks passed to LLM after re-ranking
RERANK_CANDIDATES=15    # how many vector search results to re-rank from

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail setup: myaccount.google.com → Security → App Passwords → generate one
# Other free options: Outlook (smtp.office365.com:587), Brevo (smtp-relay.brevo.com:587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx    # Gmail app password (not your real password)
EMAIL_FROM=yourname@gmail.com
APP_NAME=RecoMind
    